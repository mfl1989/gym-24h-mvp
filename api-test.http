@baseUrl = http://localhost:8080
@userId = 11111111-1111-1111-1111-111111111111
@subscriptionId = 22222222-2222-2222-2222-222222222222

### 1. Debug Login
POST {{baseUrl}}/auth/debug/login
Content-Type: application/json

{
  "userId": "{{userId}}"
}

> {%
client.global.set("authToken", response.body.data.authToken);
%}

### 2. Issue QR Token
POST {{baseUrl}}/entrances/qr-tokens/{{subscriptionId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

> {%
client.global.set("qrToken", response.body.data.qrToken);
%}

### 3. Open Door
POST {{baseUrl}}/entrances/open
Authorization: Bearer {{authToken}}
X-Request-Id: rest-client-open-1
Content-Type: application/json

{
  "qrToken": "{{qrToken}}"
}